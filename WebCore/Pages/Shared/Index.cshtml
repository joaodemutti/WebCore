style="display:flex; justify-content: space-evenly; flex-grow: 1; width: 100%;"
>
x:
<input type="number" onfocus="this.setSelectionRange(0, this.value.length)" style="width:15%;" id="ix" step="10">
y:
<input type="number" style="width:15%;" id="iy" step="10">
w:
<input type="number" style="width:15%;" id="iw">
h:
<input type="number" style="width:15%;" id="ih">
</div>
<div
style="display:flex; justify-content: space-evenly; flex-grow: 1; margin-top: 0.3rem;"
>
ox
<input type="number" style="width:15%;" id="iox">
oy
<input type="number" style="width:15%;" id="ioy">
ml
<input type="number" style="width:15%;" id="iml">
mt
<input type="number" style="width:15%;" id="imt">
</div>
</div>


<script>
	ix = document.querySelector('#ix')
	iy = document.querySelector('#iy')
	iw = document.querySelector('#iw')
	ih = document.querySelector('#ih')
	iox = document.querySelector('#iox')
	ioy = document.querySelector('#ioy')
	iml = document.querySelector('#iml')
	imt = document.querySelector('#imt')

	//debug = true
	window.playerIndex = undefined
	calculating = false
	let updateSubscription = null
	let shouldPromptRespawnOnReconnect = false
	let hasJoined = false
	let worldBounds = null
	const joinModal = document.querySelector('#joinModal')
	const deathModal = document.querySelector('#deathModal')
	const disconnectModal = document.querySelector('#disconnectModal')
	const disconnectReason = document.querySelector('#disconnectReason')
	const joinEnterBtn = document.querySelector('#joinEnterBtn')
	const deathPlayBtn = document.querySelector('#deathPlayBtn')
	const reconnectBtn = document.querySelector('#reconnectBtn')
	const joinNameInput = document.querySelector('#joinNameInput')
	const playerNameInput = document.querySelector('#playerNameInput')
	const PLAYER_NAME_KEY = 'webcore-player-name'

	const showModal = (modal) => {
		if (!modal) return
		modal.style.display = 'flex'
	}

	const hideModal = (modal) => {
		if (!modal) return
		modal.style.display = 'none'
	}

	const showJoinModal = () => {
		showModal(joinModal)
		setTimeout(() => {
			try {
				joinNameInput?.focus()
				joinNameInput?.select()
			} catch (_) { }
		}, 0)
	}
	const hideJoinModal = () => hideModal(joinModal)

	const showDeathModal = () => {
		showModal(deathModal)
		setTimeout(() => {
			try {
				playerNameInput?.focus()
				playerNameInput?.select()
			} catch (_) { }
		}, 0)
	}
	const hideDeathModal = () => hideModal(deathModal)

	const sanitizePlayerName = (name) => {
		const normalized = String(name || '').trim()
		return normalized.length > 24 ? normalized.slice(0, 24) : normalized
	}

	const persistPlayerName = (name) => {
		const sanitized = sanitizePlayerName(name)
		if (joinNameInput) joinNameInput.value = sanitized
		if (playerNameInput) playerNameInput.value = sanitized
		try {
			if (sanitized) {
				localStorage.setItem(PLAYER_NAME_KEY, sanitized)
			} else {
				localStorage.removeItem(PLAYER_NAME_KEY)
			}
		} catch (_) { }
		return sanitized
	}

	const getChosenPlayerName = () => {
		return persistPlayerName(playerNameInput?.value || '')
	}

	try {
		const cachedName = localStorage.getItem(PLAYER_NAME_KEY) || ''
		if (joinNameInput) {
			joinNameInput.value = sanitizePlayerName(cachedName)
		}
		if (playerNameInput) {
			playerNameInput.value = sanitizePlayerName(cachedName)
		}
	} catch (_) { }

	const showDisconnectModal = (reason) => {
		if (disconnectReason) {
			disconnectReason.textContent = reason || 'Connection lost.'
		}
		showModal(disconnectModal)
	}

	const hideDisconnectModal = () => hideModal(disconnectModal)
	const clamp = (value, min, max) => Math.min(max, Math.max(min, value))

	const getPlayerNameTag = (playerLike) => {
		if (!playerLike) return 'Player'
		if (playerLike.nametag) return String(playerLike.nametag)
		if (playerLike.name) return String(playerLike.name)
		return `Player ${playerLike.index}`
	}

	joinEnterBtn?.addEventListener('click', () => {
		const chosenName = persistPlayerName(joinNameInput?.value || '')
		hideJoinModal()
		Subscribe(chosenName)
	})

	joinNameInput?.addEventListener('keydown', (event) => {
		event.stopPropagation()
		if (event.key === 'Enter') {
			event.preventDefault()
			joinEnterBtn?.click()
		}
	})

	joinNameInput?.addEventListener('keyup', (event) => {
		event.stopPropagation()
	})

	deathPlayBtn?.addEventListener('click', () => {
		hideDeathModal()
		Reenter(getChosenPlayerName())
	})

	playerNameInput?.addEventListener('keydown', (event) => {
		event.stopPropagation()
		if (event.key === 'Enter') {
			event.preventDefault()
			deathPlayBtn?.click()
		}
	})

	playerNameInput?.addEventListener('keyup', (event) => {
		event.stopPropagation()
	})

	joinNameInput?.addEventListener('change', () => {
		persistPlayerName(joinNameInput?.value || '')
	})

	playerNameInput?.addEventListener('change', () => {
		persistPlayerName(playerNameInput?.value || '')
	})

	reconnectBtn?.addEventListener('click', () => {
		hideDisconnectModal()
		shouldPromptRespawnOnReconnect = true
		Subscribe()
	})

	conn.onreconnecting((err) => {
		shouldPromptRespawnOnReconnect = true
		const reason = err?.message
			? `Connection lost. Reconnecting... (${err.message})`
			: 'Connection lost. Reconnecting...'
		showDisconnectModal(reason)
	})

	conn.onreconnected(() => {
		hideDisconnectModal()
		Subscribe()
	})

	conn.onclose((err) => {
		const reason = err?.message ? `Disconnected: ${err.message}` : 'Disconnected from server.'
		showDisconnectModal(reason)
	})

function Subscribe(playerName){
	calculating = false
	const startPromise = conn.state === 'Connected'
		? Promise.resolve()
		: (conn.state === 'Disconnected' ? conn.start() : Promise.reject(new Error('Connection is not ready yet.')))
	startPromise
			.then(async _ => isFinite(window.playerIndex) ? window.playerIndex : await conn.invoke('Enter', sanitizePlayerName(playerName ?? getChosenPlayerName())))
	.then(_=>{
		hideDisconnectModal()
		hideJoinModal()
		hasJoined = true
		window.playerIndex = _
		if (shouldPromptRespawnOnReconnect) {
			showDeathModal()
			shouldPromptRespawnOnReconnect = false
		}
		if (updateSubscription) {
			updateSubscription.dispose()
		}
		updateSubscription = conn.stream('Update').subscribe({
				next: arg => 
				{
						arg.filter(p => p.isplayer).iterate((obj, k, i) => {
							try {
								if (!objects[obj.index]) {
									if (!calculating) {
										calculating = true
										Anim.LoadAnim('stormtrooper.json')
											.then(o => {
												console.log('loadedOnline')
												objects[obj.index] = new Anim(obj.copy(o))
												objects[obj.index].__draw = objects[obj.index]._afterDraw
												objects[obj.index]._afterDraw = function (ctx, x, y, key) {
													this.__draw(ctx, x, y, key)
													ctx.fillStyle = 'black'
													ctx.textAlign = 'center'
													ctx.fillText(getPlayerNameTag(this), x + (this.width / 2), y - 6)
													ctx.textAlign = 'start'

													ctx.fillStyle='red'
													ctx.fillRect(x-((60-this.width)/2), y+this.height+10, 60, 5)
													if(this.life>0){
													ctx.fillStyle = 'green'
													ctx.fillRect(x - ((60 - this.width) / 2), y + this.height + 10, 60 * (this.life / 100), 5)
													}
													ctx.fillStyle='black'
													ctx.fillText(this.kills, x - ((60 - this.width) / 2), y + this.height + 25)
												}
												calculating = false
											})
											.catch(
												_ => { console.log(_); calculating = false }
											)
									}
								}
								else
									obj.maintainUndefined(objects[obj.index])

								if (obj.index === window.playerIndex) {
									if (obj.dead || obj.life <= 0) {
										showDeathModal()
									} else {
										hideDeathModal()
									}
								}

							} catch (ex) { console.log(ex) }
						})
						arg.filter(p => p.isbullet).iterate((obj, k, i) => {
							try {
								if (!objects[obj.index]) {
										objects[obj.index] = new Bullet(obj.index,obj);
										obj.maintainUndefined(objects[obj.index])
								}
								else
									obj.maintainUndefined(objects[obj.index])

							} catch (ex) { console.log(ex); }
						})
				},
				error: (err) => {
					console.log(err)
					showDisconnectModal('Disconnected while receiving updates.')
				}
		})
	})
	.catch(err => {
		console.log(err)
		showDisconnectModal('Unable to connect. Try reconnecting.')
	})
}

showJoinModal()
	objects['camerafollow'] =
		(ctx) =>
			{
			const player = objects[window.playerIndex]
			if (!player) return
			const desiredX = ((ctx.canvas.width / 2) - (objects[window.playerIndex].width / 2)) - objects[window.playerIndex].x
			const desiredY = ((ctx.canvas.height / 2) - (objects[window.playerIndex].height / 2)) - objects[window.playerIndex].y

			if (worldBounds) {
				const minX = ctx.canvas.width - worldBounds.halfWidth
				const maxX = worldBounds.halfWidth
				const minY = ctx.canvas.height - worldBounds.halfHeight
				const maxY = worldBounds.halfHeight
				Engine.offset.x = clamp(desiredX, minX, maxX)
				Engine.offset.y = clamp(desiredY, minY, maxY)
			} else {
				Engine.offset.x = desiredX
				Engine.offset.y = desiredY
			}
				offset.x = Engine.offset.x
				offset.y = Engine.offset.y
			}
a = async () => {
		let state = true
		await fetch('').catch(_ => state = false)

		if (state)
			return fetch('background.png').then(_ => _.blob())
				.then(i => createImageBitmap(i))
					.then(img =>{ 
						worldBounds = { halfWidth: img.width / 2, halfHeight: img.height / 2 }
						objects[-1] = ctx => {
						ctx.globalCompositeOperation = 'destination-over';
						ctx.drawImage(img, Engine.offset.x - (img.width / 2), Engine.offset.y - (img.height / 2))
						ctx.globalCompositeOperation = 'source-over';
					}
						
					})
		else
			return readFile('background.png')
				.then(i => createImageBitmap(i))
					.then(img =>{
					worldBounds = { halfWidth: img.width / 2, halfHeight: img.height / 2 }


					objects[-1] = ctx => {
						ctx.globalCompositeOperation = 'destination-over';
						ctx.drawImage(img, Engine.offset.x - (img.width / 2), Engine.offset.y - (img.height / 2))
						ctx.globalCompositeOperation = 'source-over';
					}


				})

	}
	a()


	function Reenter(playerName){
		conn?.invoke('Enter', sanitizePlayerName(playerName)).then(_ => {
		window.playerIndex = _
		hideDeathModal()
	})
	}
</script>
