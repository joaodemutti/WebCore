<style>
	.game-modal-overlay {
		position: fixed;
		inset: 0;
		display: none;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.55);
		z-index: 9999;
	}

	.game-modal {
		min-width: 260px;
		max-width: 90vw;
		padding: 1rem;
		border-radius: 12px;
		background: #f1f1f1;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
		text-align: center;
	}

	.game-modal h3 {
		margin: 0 0 0.5rem 0;
	}

	.game-modal p {
		margin: 0 0 0.85rem 0;
	}

	.game-modal button {
		border: none;
		padding: 0.55rem 0.95rem;
		border-radius: 8px;
		cursor: pointer;
		font-weight: 600;
		background: #1f7a1f;
		color: #fff;
	}

	.game-modal input,
	.game-modal textarea,
	.game-modal select,
	.game-modal button {
		-webkit-touch-callout: default;
		-webkit-user-select: text;
		-khtml-user-select: text;
		-moz-user-select: text;
		-ms-user-select: text;
		user-select: text;
		outline: auto;
	}
</style>

<link rel="manifest" href="./manifest.json" src="./manifest.json" >



<canvas id="canvas" >
</canvas>


<script src="~/js/engine.js"></script>

